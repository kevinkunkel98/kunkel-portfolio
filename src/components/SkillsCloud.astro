---
// Icons available on skillicons.dev — rendered as <img> tags
// Icons NOT on skillicons.dev (langchain, huggingface, mlflow, ollama) — use simple-icons with brand bg
import { siLangchain, siHuggingface, siMlflow, siOllama } from 'simple-icons';

interface SkillEntry {
  slug?: string;           // skillicons.dev slug (if available)
  siIcon?: { svg: string; hex: string; title: string }; // simple-icons fallback
  label: string;
  left: number;
  top: number;
  dur: number;
  delay: number;
  tx1: number; ty1: number;
  tx2: number; ty2: number;
  tx3: number; ty3: number;
}

function luminance(hex: string): number {
  const r = parseInt(hex.slice(0, 2), 16) / 255;
  const g = parseInt(hex.slice(2, 4), 16) / 255;
  const b = parseInt(hex.slice(4, 6), 16) / 255;
  const toLinear = (c: number) => c <= 0.03928 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4;
  return 0.2126 * toLinear(r) + 0.7152 * toLinear(g) + 0.0722 * toLinear(b);
}

function iconFill(hex: string): string {
  return luminance(hex) > 0.35 ? '#1a1a2e' : '#ffffff';
}

const skills: SkillEntry[] = [
  { slug: 'py',            label: 'Python',         left:  6, top:  4, dur: 18, delay:  0, tx1: 12, ty1:  8, tx2: -8, ty2: 14, tx3:  6, ty3: -10 },
  { slug: 'ts',            label: 'TypeScript',     left: 20, top:  2, dur: 15, delay: -3, tx1: -6, ty1: 10, tx2: 10, ty2: -8, tx3: -4, ty3:  12 },
  { slug: 'js',            label: 'JavaScript',     left: 35, top:  6, dur: 20, delay: -7, tx1:  8, ty1: -6, tx2: -10,ty2: 10, tx3:  4, ty3: -14 },
  { slug: 'react',         label: 'React',          left: 50, top:  2, dur: 16, delay: -2, tx1: -8, ty1: 12, tx2:  6, ty2: -10,tx3: 10, ty3:   8 },
  { slug: 'obsidian',      label: 'Obsidian',       left: 65, top:  8, dur: 22, delay: -9, tx1: 10, ty1:  6, tx2: -6, ty2: -12,tx3:  8, ty3:  10 },
  { slug: 'astro',         label: 'Astro',          left: 80, top:  3, dur: 17, delay: -5, tx1: -4, ty1: -8, tx2:  8, ty2: 10, tx3: -10,ty3:  6 },
  { slug: 'arch',          label: 'Arch',           left:  2, top: 26, dur: 19, delay: -1, tx1:  6, ty1: 10, tx2: -8, ty2: -6, tx3: 12, ty3:  4 },
  { slug: 'fastapi',       label: 'FastAPI',        left: 15, top: 36, dur: 14, delay: -6, tx1: -10,ty1:  8, tx2:  4, ty2: -12,tx3:  8, ty3:  6 },
  { slug: 'spring',        label: 'Spring',         left: 29, top: 28, dur: 21, delay: -4, tx1:  8, ty1: -4, tx2: -6, ty2:  8, tx3: -12,ty3: -6 },
  { slug: 'docker',        label: 'Docker',         left: 44, top: 32, dur: 16, delay: -8, tx1: -6, ty1: -10,tx2: 10, ty2:  6, tx3: -8, ty3: 12 },
  { slug: 'kubernetes',    label: 'Kubernetes',     left: 58, top: 26, dur: 18, delay: -3, tx1:  4, ty1: 12, tx2: -8, ty2: -8, tx3: 10, ty3:  4 },
  { slug: 'postgres',      label: 'PostgreSQL',     left: 72, top: 34, dur: 23, delay: -7, tx1: -8, ty1:  6, tx2:  6, ty2: -10,tx3: -4, ty3:  8 },
  { slug: 'mongodb',       label: 'MongoDB',        left: 86, top: 28, dur: 15, delay: -2, tx1: 10, ty1: -8, tx2: -4, ty2: 10, tx3:  6, ty3: -6 },
  { slug: 'pytorch',       label: 'PyTorch',        left:  2, top: 54, dur: 20, delay: -5, tx1: -6, ty1:  8, tx2: 10, ty2: -6, tx3: -8, ty3: 10 },
  { slug: 'sklearn',       label: 'scikit-learn',   left: 27, top: 58, dur: 22, delay: -1, tx1: -4, ty1: -6, tx2:  8, ty2: 10, tx3: -6, ty3: -4 },
  { slug: 'git',           label: 'Git',            left: 70, top: 60, dur: 16, delay: -8, tx1: 10, ty1: -6, tx2: -6, ty2:  8, tx3:  4, ty3: -10 },
  { siIcon: siMlflow,      label: 'MLflow',         left:  8, top: 74, dur: 18, delay: -7, tx1:  6, ty1: -8, tx2: -8, ty2:  6, tx3: 10, ty3: -4 },
  { slug: 'linux',         label: 'Linux',          left: 22, top: 78, dur: 15, delay: -2, tx1: -4, ty1: 10, tx2:  8, ty2: -8, tx3: -6, ty3:  6 },
  { slug: 'vim',           label: 'Vim',            left: 40, top: 72, dur: 20, delay: -5, tx1:  8, ty1:  6, tx2: -6, ty2: -10,tx3:  4, ty3:  8 },
  { slug: 'tailwind',      label: 'Tailwind CSS',   left: 54, top: 76, dur: 23, delay: -9, tx1: -8, ty1: -6, tx2:  6, ty2:  8, tx3: -4, ty3: -8 },
  { slug: 'java',          label: 'Java',           left: 80, top: 72, dur: 14, delay: -6, tx1: -6, ty1:  6, tx2: 10, ty2: -8, tx3: -8, ty3:  4 },
];
---

<div class="skills-cloud-wrap">
  <div class="skills-cloud">
    {skills.map((entry, i) => (
      <div
        class={`skill-badge badge-${i}`}
        title={entry.label}
        style={`left:${entry.left}%;top:${entry.top}%;animation-duration:${entry.dur}s;animation-delay:${entry.delay}s;--tx1:${entry.tx1}px;--ty1:${entry.ty1}px;--tx2:${entry.tx2}px;--ty2:${entry.ty2}px;--tx3:${entry.tx3}px;--ty3:${entry.ty3}px;${entry.siIcon ? `--bg-color:#${entry.siIcon.hex};--icon-fill:${iconFill(entry.siIcon.hex)};` : ''}`}
      >
        {entry.slug ? (
          <img
            src={`https://skillicons.dev/icons?i=${entry.slug}`}
            alt={entry.label}
            width="92"
            height="92"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <span class="badge-icon" set:html={entry.siIcon!.svg} />
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .skills-cloud-wrap {
    padding: 1rem 0 2rem;
  }

  .skills-cloud {
    position: relative;
    width: 100%;
    min-height: 300px;
  }

  /* Base badge — skillicons.dev img tiles are self-contained (no background needed) */
  .skill-badge {
    position: absolute;
    width: 64px;
    height: 64px;
    border-radius: 22%;
    display: flex;
    align-items: center;
    justify-content: center;
    /* background set inline only for simple-icons fallbacks */
    animation-name: float-drift;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-direction: alternate;
    opacity: 0.92;
    transition: opacity 0.2s, transform 0.2s;
    cursor: default;
    overflow: hidden;
  }

  /* skillicons.dev img fills the badge exactly */
  .skill-badge img {
    width: 64px;
    height: 64px;
    display: block;
    border-radius: 22%;
  }

  /* simple-icons fallback tiles */
  .skill-badge:has(.badge-icon) {
    background: var(--bg-color);
  }

  .skill-badge:hover {
    opacity: 1;
    z-index: 10;
    transform: scale(1.08);
  }

  /* simple-icons fallback icon */
  .badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
  }

  .badge-icon :global(svg) {
    fill: var(--icon-fill) !important;
    width: 36px;
    height: 36px;
  }

  @keyframes float-drift {
    0%   { transform: translate(0, 0); }
    33%  { transform: translate(var(--tx1), var(--ty1)); }
    66%  { transform: translate(var(--tx2), var(--ty2)); }
    100% { transform: translate(var(--tx3), var(--ty3)); }
  }

  @media (max-width: 639px) {
    .skills-cloud {
      min-height: 360px;
    }

    .skill-badge {
      width: 48px;
      height: 48px;
    }

    .skill-badge img {
      width: 48px;
      height: 48px;
    }

    .badge-icon,
    .badge-icon :global(svg) {
      width: 28px;
      height: 28px;
    }
  }
</style>
