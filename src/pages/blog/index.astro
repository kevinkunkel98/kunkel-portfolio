---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerminalCard from '../../components/TerminalCard.astro';

const models = [
  {
    href: '/blog/linear-regression',
    filename: 'linear-regression.py',
    svg: '/assets/blog/linear-regression.svg',
    name: 'Linear Regression',
    description: 'Predicts continuous values by fitting a linear equation. Best for trends and forecasting.',
  },
  {
    href: '/blog/logistic-regression',
    filename: 'logistic-regression.py',
    svg: '/assets/blog/logistic-regression.svg',
    name: 'Logistic Regression',
    description: 'Binary classification using sigmoid function. Outputs probability between 0 and 1.',
  },
  {
    href: '/blog/support-vector-machines',
    filename: 'support-vector-machines.py',
    svg: '/assets/blog/support-vector-machines.svg',
    name: 'Support Vector Machines',
    description: 'Finds optimal hyperplane to separate classes. Powerful for high-dimensional spaces.',
  },
  {
    href: '/blog/decision-trees',
    filename: 'decision-trees.py',
    svg: '/assets/blog/decision-trees.svg',
    name: 'Decision Trees',
    description: 'Tree-like decision model. Easy to interpret and visualize decision paths.',
  },
  {
    href: '/blog/random-forest',
    filename: 'random-forest.py',
    svg: '/assets/blog/random-forest.svg',
    name: 'Random Forest',
    description: 'Ensemble of decision trees. Reduces overfitting through bagging and voting.',
  },
  {
    href: '/blog/k-nearest-neighbors',
    filename: 'k-nearest-neighbors.py',
    svg: '/assets/blog/k-nearest-neighbors.svg',
    name: 'K-Nearest Neighbors',
    description: 'Classifies based on nearest neighbors. Simple yet effective for many tasks.',
  },
];
---

<BaseLayout title="ML Models Playground - Kevin Kunkel" description="Interactive overview of machine learning models and algorithms">

  <!-- Header Section -->
  <section class="blog-header">
    <div class="blog-header-inner">
      <div class="blog-header-text">
        <div class="blog-title">// python3 ml_models.py --explore</div>
        <div class="blog-subtitle"># Interactive ML Models Playground</div>
      </div>
    </div>
  </section>

  <!-- ML Models Grid -->
  <section class="blog-grid-section">
    <div class="blog-grid-inner">
      <div class="blog-grid">
        {models.map((model) => (
          <a href={model.href} class="card-link">
            <TerminalCard filename={model.filename}>
              <img
                src={model.svg}
                alt={`${model.name} plot`}
                class="card-plot"
              />
              <div class="card-body">
                <div class="card-heading">
                  <h3 class="card-name">{model.name}</h3>
                </div>
                <p class="card-description">{model.description}</p>
                <div class="card-prompt">
                  <span class="prompt-dollar">$</span>
                  <span class="prompt-cmd">cat ./{model.filename.replace('.py', '.md')} →</span>
                </div>
              </div>
            </TerminalCard>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .blog-header {
    padding: 3rem 0 2rem;
  }

  .blog-header-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .blog-header-text {
    text-align: center;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Monaco, Consolas, monospace;
  }

  .blog-title {
    font-size: clamp(1.125rem, 3vw, 2rem);
    color: var(--accent-magenta);
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .blog-subtitle {
    font-size: 0.875rem;
    color: var(--text-muted);
    max-width: 48rem;
    margin: 0 auto;
  }

  .blog-grid-section {
    padding: 2rem 0 4rem;
  }

  .blog-grid-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card-link:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-plot {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid var(--border);
  }

  .card-heading {
    display: flex;
    align-items: center;
  }

  .card-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Monaco, Consolas, monospace;
    margin: 0;
  }

  .card-description {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .card-prompt {
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
  }

  .prompt-dollar {
    color: var(--accent-magenta);
  }

  .prompt-cmd {
    color: var(--text-muted);
  }
</style>
