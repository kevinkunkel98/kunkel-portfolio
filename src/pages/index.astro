---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalCard from '../components/TerminalCard.astro';
import LossLandscape from '../components/LossLandscape';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import SkillGraph from '../components/SkillGraph';
import ContactForm from '../components/ContactForm';
import ChatWidget from '../components/ChatWidget';
import ProjectsSection from '../components/ProjectsSection';
---

<BaseLayout
  title="Kevin Kunkel - dev && ml_engineer"
  description="Kevin Kunkel - ML Engineer & AI-focused Full-Stack Developer. Building ML, LLM, and scalable web systems."
  image="/optimized-og.png"
  url="/"
>

  <!-- Hidden static form for Netlify Forms crawler -->
  <form name="contact" data-netlify="true" netlify-honeypot="bot-field" hidden>
    <input type="text" name="name" />
    <input type="email" name="email" />
    <textarea name="message"></textarea>
    <input name="bot-field" />
  </form>

  <!-- ═══════════════════════════════════════ HERO ═══════════════════════════════════════ -->
  <section id="hero" style="position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center; overflow: hidden; background: var(--bg-base);">
    <LossLandscape client:load />
    <div style="position: relative; z-index: 1; text-align: center; padding: 2rem 1rem; max-width: 56rem; width: 100%;">
      <div style="font-size: 1.4rem; letter-spacing: 0.2em; color: var(--text-muted); text-transform: uppercase; margin-bottom: 1rem;">
        Kevin Kunkel
      </div>
      <h1 style="font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 700; color: var(--text-primary); line-height: 1.1; margin: 0 0 1rem 0;">
        ML Engineer &amp;<br/>Web Developer
      </h1>
      <p style="color: var(--text-secondary); font-size: 1.1rem; margin: 0 0 2.5rem 0;">
        Leipzig, DE — building things that learn
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="#projects" class="btn-primary">$ view projects →</a>
        <a href="#about" class="btn-secondary">$ about me →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ ABOUT ══════════════════════════════════════ -->
  <section id="about" style="padding: 5rem 1rem; background: var(--bg-base);">
    <div style="max-width: 56rem; margin: 0 auto;">

      <div class="section-heading">// about</div>

      <!-- Bio card -->
      <div style="margin-bottom: 1.5rem;">
        <TerminalCard filename="kevin.md">
          <div class="about-grid">

            <!-- Profile image -->
            <div class="about-image-col">
              <div class="about-image-wrap">
                <!-- DROP YOUR PHOTO HERE — replace the src below -->
                <img
                  src="/kevin-hero.jpg"
                  alt="Kevin Kunkel"
                  class="about-img"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
                <!-- Placeholder shown when image is missing -->
                <div class="about-img-placeholder">
                  <span style="font-size:2rem; color: var(--accent-violet);">~/kevin</span>
                </div>
              </div>
            </div>

            <!-- Bio text -->
            <div class="about-text-col">
              <h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin: 0 0 1rem;">
                Kevin Kunkel
              </h2>
              <p style="font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7; margin: 0 0 0.75rem;">
                ML engineer and web developer based in Leipzig, Germany.
                I started my journey in tech as a fullstack developer, but quickly found myself drawn to the world of machine learning and AI. I love building things that actually work and that people actually use, whether it's a sleek web app or a complex ML model.
                My personal motto is "scalps not sledgehammers".
              </p>
              <p style="font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7; margin: 0;">
                Currently studying computer science and spending too much time on my Neovim config.
              </p>
              <div style="margin-top: 1.25rem; display: flex; gap: 0.75rem; flex-wrap: wrap;">
                <a href="#projects" style="font-size: 0.8125rem; color: var(--accent-magenta); text-decoration: none;">$ ls ./projects →</a>
                <a href="#contact" style="font-size: 0.8125rem; color: var(--accent-magenta); text-decoration: none;">$ ./contact.sh →</a>
              </div>
            </div>

          </div>
        </TerminalCard>
      </div>

      <!-- Experience Timeline -->
      <ExperienceTimeline />

      <!-- Education -->
      <div style="margin-bottom: 2rem;">
        <TerminalCard filename="cv.md">
          <div style="padding: 1.5rem;">

            <div style="margin-bottom: 1.75rem;">
              <div style="font-size: 0.75rem; color: var(--accent-violet); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                Education
              </div>
              <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                <div>
                  <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.25rem;">
                    <div style="font-size: 0.9rem; font-weight: 600; color: var(--text-primary);">M.Sc. Computer Science</div>
                    <div style="font-size: 0.75rem; color: var(--accent-magenta); flex-shrink: 0;">2021 — present</div>
                  </div>
                  <div style="font-size: 0.8125rem; color: var(--accent-violet);">University of Leipzig · Leipzig, DE</div>
                  <div style="font-size: 0.8125rem; color: var(--text-muted); margin-top: 0.35rem; line-height: 1.6;">
                    Part-time alongside professional work; 3 years as elected FSR Informatik member and Prüfungsausschuss representative, co-shaping faculty exam regulations.
                  </div>
                </div>
                <div style="padding-top: 1.25rem; border-top: 1px solid var(--border);">
                  <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.25rem;">
                    <div style="font-size: 0.9rem; font-weight: 600; color: var(--text-primary);">B.Sc. Business Informatics</div>
                    <div style="font-size: 0.75rem; color: var(--accent-magenta); flex-shrink: 0;">2017 — 2020</div>
                  </div>
                  <div style="font-size: 0.8125rem; color: var(--accent-violet);">Berufsakademie Rhein-Main · Frankfurt, DE</div>
                  <div style="font-size: 0.8125rem; color: var(--text-muted); margin-top: 0.35rem; line-height: 1.6;">
                    Dual study program — completed while working full-time, combining CS fundamentals with business and management.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </TerminalCard>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════ SKILLS ═════════════════════════════════════ -->
  <section id="skills" style="padding: 5rem 1rem; background: var(--bg-base);">
    <div style="max-width: 80rem; margin: 0 auto;">
      <div class="section-heading">// skills</div>
      <SkillGraph client:load />

      <!-- Code stack cards -->
      <div class="skills-grid" style="margin-top: 2.5rem; margin-bottom: 2rem;">

        <!-- ML Stack -->
        <TerminalCard filename="ml_stack.py">
          <div style="padding: 1.25rem 1.5rem; font-size: 0.8rem; color: var(--text-secondary); line-height: 1.8; overflow-x: auto;">
            <div style="color: #28ca41;"># Daily drivers</div>
            <div><span style="color: var(--accent-violet);">import</span> torch, tensorflow <span style="color: var(--text-muted);"># The usual suspects</span></div>
            <div><span style="color: var(--accent-violet);">from</span> transformers <span style="color: var(--accent-violet);">import</span> * <span style="color: var(--text-muted);"># HuggingFace magic</span></div>
            <div><span style="color: var(--accent-violet);">import</span> numpy, pandas <span style="color: var(--text-muted);"># Data wrangling</span></div>
            <div style="color: #28ca41; padding-top: 0.5rem;"># When things get visual</div>
            <div><span style="color: var(--accent-violet);">import</span> cv2, matplotlib</div>
            <div style="color: #28ca41; padding-top: 0.5rem;"># Deployment &amp; MLOps</div>
            <div><span style="color: var(--accent-violet);">import</span> mlflow, docker</div>
            <div style="color: #28ca41; padding-top: 0.5rem;"># Classical NLP &amp; Linear models</div>
            <div><span style="color: var(--accent-violet);">from</span> sklearn.feature_extraction.text <span style="color: var(--accent-violet);">import</span> TfidfVectorizer</div>
            <div><span style="color: var(--accent-violet);">from</span> sklearn.svm <span style="color: var(--accent-violet);">import</span> LinearSVC <span style="color: var(--text-muted);"># Fast linear classifier</span></div>
            <div><span style="color: var(--accent-violet);">from</span> sklearn.pipeline <span style="color: var(--accent-violet);">import</span> make_pipeline</div>
            <div style="word-break: break-all;"><span style="color: var(--accent-violet);">model</span> = make_pipeline(TfidfVectorizer(max_features=10_000), LinearSVC()) <span style="color: var(--text-muted);"># Text → features → classification</span></div>
          </div>
        </TerminalCard>

        <!-- Web Stack -->
        <TerminalCard filename="package.json">
          <div style="padding: 1.25rem 1.5rem; font-size: 0.8rem; color: var(--text-secondary); line-height: 1.8; overflow-x: auto;">
            <div style="color: var(--accent-magenta);">{"{"}</div>
            <div style="margin-left: 1.5rem;"><span style="color: #28ca41;">"dependencies"</span>: {"{"}</div>
            <div style="margin-left: 3rem;"><span style="color: #28ca41;">"react"</span>: <span style="color: var(--accent-magenta);">"^19.x"</span>, <span style="color: var(--text-muted);">// Still the GOAT</span></div>
            <div style="margin-left: 3rem;"><span style="color: #28ca41;">"typescript"</span>: <span style="color: var(--accent-magenta);">"latest"</span>, <span style="color: var(--text-muted);">// Life saver</span></div>
            <div style="margin-left: 3rem;"><span style="color: #28ca41;">"astro"</span>: <span style="color: var(--accent-magenta);">"^5.x"</span>, <span style="color: var(--text-muted);">// Static site magic</span></div>
            <div style="margin-left: 3rem;"><span style="color: #28ca41;">"next.js"</span>: <span style="color: var(--accent-magenta);">"^15.x"</span>, <span style="color: var(--text-muted);">// Full-stack magic</span></div>
            <div style="margin-left: 3rem;"><span style="color: #28ca41;">"node.js"</span>: <span style="color: var(--accent-magenta);">"LTS"</span>, <span style="color: var(--text-muted);">// Backend buddy</span></div>
            <div style="margin-left: 3rem;"><span style="color: #28ca41;">"postgresql"</span>: <span style="color: var(--accent-magenta);">"^15"</span>, <span style="color: var(--text-muted);">// Reliable data</span></div>
            <div style="margin-left: 3rem;"><span style="color: #28ca41;">"vite"</span>: <span style="color: var(--accent-magenta);">"latest"</span>, <span style="color: var(--text-muted);">// Lightning fast builds</span></div>
            <div style="margin-left: 3rem;"><span style="color: #28ca41;">"tailwindcss"</span>: <span style="color: var(--accent-magenta);">"latest"</span>, <span style="color: var(--text-muted);">// Utility-first styling</span></div>
            <div style="margin-left: 3rem;"><span style="color: #28ca41;">"docker"</span>: <span style="color: var(--accent-magenta);">"latest"</span> <span style="color: var(--text-muted);">// It works on my machine™</span></div>
            <div style="margin-left: 1.5rem;">{"}"}</div>
            <div style="color: var(--accent-magenta);">{"}"}</div>
          </div>
        </TerminalCard>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ PROJECTS ══════════════════════════════════ -->
  <section id="projects" style="padding: 5rem 1rem; background: var(--bg-base);">
    <div style="max-width: 80rem; margin: 0 auto;">
      <div class="section-heading">// projects</div>
      <ProjectsSection client:load />
    </div>
  </section>

  <!-- ═══════════════════════════════════════ CONTACT ═══════════════════════════════════ -->
  <section id="contact" style="padding: 5rem 1rem; background: var(--bg-base);">
    <div style="max-width: 40rem; margin: 0 auto;">
      <div class="section-heading">// contact</div>
      <p style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1.5rem; text-align: center;">
        # Get in touch for opportunities, collaborations, or just to say hello
      </p>
      <TerminalCard filename="contact.sh">
        <div style="padding: 1.5rem;">
          <ContactForm client:load />
        </div>
      </TerminalCard>
    </div>
  </section>

  <!-- Floating AI chat widget -->
  <ChatWidget client:load />

</BaseLayout>

<style>
  .btn-primary, .btn-secondary {
    font-family: inherit;
    font-size: 0.9rem;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    border: 4px solid transparent;
    text-decoration: none;
    min-width: 13rem;
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .btn-primary {
    background: var(--accent-violet);
    color: #fff;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--accent-violet) 50%, transparent);
  }

  .btn-secondary {
    border-color: var(--border);
    color: var(--text-secondary);
  }
  .btn-secondary:hover {
    transform: translateY(-2px);
    border-color: var(--accent-violet);
    color: var(--accent-violet);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--accent-violet) 25%, transparent);
  }

  /* ── About two-column layout ── */
  .about-grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    padding: 1.5rem;
    align-items: start;
  }

  .about-image-col {
    display: flex;
    justify-content: center;
  }

  .about-image-wrap {
    position: relative;
    width: 180px;
    height: 220px;
    border-radius: 6px;
    overflow: hidden;
    border: 2px solid var(--border);
    flex-shrink: 0;
  }

  .about-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .about-img-placeholder {
    display: none;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    background: var(--bg-elevated);
    font-family: inherit;
  }

  .about-text-col {
    padding-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .about-image-wrap {
      width: 140px;
      height: 170px;
    }
  }

  .section-heading {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--accent-magenta);
    font-weight: 600;
    text-align: center;
    margin-bottom: 2rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 639px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }

  .stack-grid {
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .stack-grid {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }

</style>
